# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# Public site URL including scheme. Must match the deployed URL (Vercel: set per env).
# Wrong ORIGIN breaks cookies, OAuth redirects, and Stripe return URLs.
# GitHub OAuth app "Authorization callback URL" must be:
#   {ORIGIN}/api/auth/callback/github
ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# GitHub OAuth (optional — leave commented out if you're not using GitHub sign-in)
# https://www.better-auth.com/docs/authentication/github
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
